    rdfs:subPropertyOf dd:is-version-of ;
    owl:inverseOf dd:has-version-of-term ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    rdfs:domain dd:version-of-term ;
    rdfs:range dd:term ;
    skos:prefLabel "Is version of term"@en, "Je verzí pojmu"@cs .

#dd:má-verzi
dd:has-version a skos:Concept, owl:ObjectProperty ;
    owl:inverseOf dd:is-version-of ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    rdfs:domain owl:Thing ;
    rdfs:range dd:version-of-object ;
    skos:prefLabel "Has version "@en, "Má verzi"@cs .


#dd:má-verzi-pojmu
dd:has-version-of-term a skos:Concept, owl:ObjectProperty ;
    owl:inverseOf dd:is-version-of-term ;
    rdfs:subPropertyOf dd:has-version ;
