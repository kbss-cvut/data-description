#dd:má-křestní-jméno (křestní škrtni) a skos:Concept . 
dd:has-first-name a skos:Concept, owl:DatatypeProperty ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    rdfs:domain dd:user ;
    rdfs:range xsd:string ;
    skos:prefLabel "Has first name"@en, "Má jméno"@cs ;
    rdfs:comment "First name of a user."@en, "Osobní jméno uživatele."@cs ;
    skos:definition "First name of a user."@en, "Osobní jméno uživatele."@cs ;
    skos:scopeNote "Jedná se pouze o křestní jméno, nikoliv příjmení."@cs ;
    dct:description "Jedná se pouze o křestní jméno, nikoliv příjmení."@cs .

