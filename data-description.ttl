    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    rdfs:domain dd:update-of-entity ;
    rdfs:range rdfs:Resource ;
    skos:prefLabel "Has new value"@en, "Má novou hodnotu"@cs .
    #Definition: "Points to the new value of the entity during the change"

#dd:má-původní-hodnotu a skos:Concept . 
dd:has-original-value a skos:Concept, owl:AnnotationProperty ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    rdfs:domain dd:update-of-entity ;
    rdfs:range rdfs:Resource ;
    skos:prefLabel "Has original value"@en, "Má původní hodnotu"@cs .
    #Definition: "Points to the original value of the entity during the change"

#dd:verze-objektu a skos:Concept . 
