    rdfs:domain dd:vocabulary ;
    rdfs:range dd:version-of-vocabulary ;
    skos:prefLabel "Má verzi slovníku"@cs, "Has vocabulary version"@en .

#dd:má-datum-a-čas-vytvoření-verze a skos:Concept . 
dd:has-date-and-time-of-creation-of-version a skos:Concept, owl:DatatypeProperty ;
