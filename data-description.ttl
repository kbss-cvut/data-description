#dd:je-verzí a skos:Concept . 
dd:is-version-of a skos:Concept, owl:ObjectProperty ;
    owl:inverseOf dd:has-version ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    rdfs:domain dd:version-of-object ;
    rdfs:range owl:Thing ;
    skos:prefLabel "Is version of"@en, "Je verzí"@cs .

#dd:je-verzí-slovníku a skos:Concept . 
dd:is-version-of-vocabulary a skos:Concept, owl:ObjectProperty ;
    rdfs:subPropertyOf dd:is-version-of ;
    owl:inverseOf dd:has-version-of-vocabulary ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    rdfs:domain dd:version-of-vocabulary ;
    rdfs:range dd:vocabulary ;
    skos:prefLabel "Is version of vocabulary"@en, "Je verzí slovníku"@cs .

#dd:je-verzí-pojmu a skos:Concept . 
