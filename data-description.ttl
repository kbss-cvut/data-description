<https://orcid.org/0000-0002-2451-2348> rdf:type owl:NamedIndividual ,
                                                 owl:Person ;
                                        org:memberOf <https://ror.org/03kqpb082> ;
                                        foaf:name "Martin Ledvinka" .

###  https://orcid.org/0000-0002-3844-426X
<https://orcid.org/0000-0002-3844-426X> rdf:type owl:NamedIndividual ,
                                                 owl:Person ;
                                        org:memberOf <https://ror.org/03kqpb082> ;
                                        foaf:name "Michal Med" . 

###  https://ror.org/03kqpb082
<https://ror.org/03kqpb082> rdf:type owl:NamedIndividual ,
                                     owl:Organization ;
                            foaf:name "České vysoké učení technické v Praze"@cs .

#dd:term
dd:term a skos:Concept, owl:Class ;
    rdfs:subClassOf dd:record ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    skos:prefLabel "Term"@en, "Pojem"@cs .

#dd:je-pojmem a skos:Concept .
dd:is-term-of a skos:Concept, owl:ObjectProperty;
    rdfs:subPropertyOf dd:is-record-of ;
    skos:broader dd:is-record-of ;
    rdfs:domain dd:term ;
    rdfs:range owl:Thing  ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    skos:prefLabel "Is term of"@en, "Je pojmem"@cs .

#dd:je-záznamem a skos:Concept . 
dd:is-record-of a skos:Concept, owl:ObjectProperty ;
    rdfs:domain dd:record ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    skos:prefLabel "Is record of"@en, "Je záznamem"@cs .

#dd:číselník a skos:Concept . 
dd:codelist a skos:Concept, owl:Class ;
    rdfs:subClassOf dd:database-table ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    skos:prefLabel "Codelist"@en, "Číselník"@cs .

#dd:databázová-tabulka a skos:Concept . 
dd:database-table a skos:Concept, owl:Class ;
    rdfs:subClassOf owl:Thing ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    skos:prefLabel "Database table"@en, "Databázová tabulka"@cs .

#dd:má-heslo a skos:Concept . 
dd:has-password a skos:Concept, owl:DatatypeProperty ;
    rdfs:domain dd:user ;
    rdfs:range rdfs:Literal ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    skos:prefLabel "Has password"@en, "Má heslo"@cs .

#dd:má-posledního-editora a skos:Concept . 
dd:has-last-editor a skos:Concept, owl:ObjectProperty ;
    rdfs:subPropertyOf dd:has-editor  ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    skos:prefLabel "Má posledního editora"@cs, "Has last editor"@en .

#dd:má-editora a skos:Concept . 
dd:has-editor a skos:Concept, owl:ObjectProperty  ;
    rdfs:domain owl:Thing ;
    rdfs:range dd:user ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    skos:prefLabel "Has editor"@en, "Má editora"@cs .

#dd:má-datový-typ a skos:Concept . 
dd:has-data-type a skos:Concept, owl:ObjectProperty  ;
    rdfs:domain dd:attribute-of-database-table ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    skos:prefLabel "Has data type"@en, "Má datový typ"@cs .

#dd:záznam a skos:Concept . 
dd:record a skos:Concept, owl:Class ;
    rdfs:subClassOf skos:Concept  ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    skos:prefLabel "Record"@en, "Záznam"@cs .

#dd:je-záznamem-datové-sady a skos:Concept .
dd:is-record-of-dataset a skos:Concept, owl:ObjectProperty ;
    rdfs:subPropertyOf dd:is-record-of ;
    rdfs:range dd:dataset ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
  skos:prefLabel "Is record of data set"@en, "Je záznamem datové sady"@cs . 

#dd:poskytuje-záznam a skos:Concept . 
dd:provides-record a skos:Concept, owl:ObjectProperty  ;
    rdfs:domain dd:source-of-record ;
    rdfs:range dd:record ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    skos:prefLabel "Provides record"@en, "Poskytuje záznam"@cs .

#dd:statistický-atribut-záznamu a skos:Concept . 
dd:statistic-attribute-of-record a skos:Concept, owl:Class ;
    rdfs:subClassOf dd:attribute-of-record  ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    skos:prefLabel "Statistic attribute of record"@en,
    "Statistický atribut záznamu"@cs .
 
#dd:atribut-záznamu a skos:Concept . 
dd:attribute-of-record a skos:Concept, owl:Class ;
    rdfs:subClassOf dd:attribute  ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    skos:prefLabel "Attribute of record"@en, "Atribut záznamu"@cs .

#dd:má-dokumentový-slovník a skos:Concept . 
dd:has-document-vocabulary a skos:Concept, owl:ObjectProperty  ;
    owl:inverseOf dd:describes-document ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    rdfs:domain dd:document ;
    rdfs:range dd:vocabulary ;
    skos:prefLabel "Has document vocabulary"@en, "Má dokumentový slovník"@cs .

#dd:má-atribut a skos:Concept . 
dd:has-attribute a skos:Concept, owl:ObjectProperty  ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    rdfs:domain owl:Thing ;
    rdfs:range dd:attribute ;
    skos:prefLabel "Has attribute"@en, "Má atribut"@cs .

#dd:soubor a skos:Concept . 
dd:file a skos:Concept, owl:Class ;
    rdfs:subClassOf dd:resource  ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    skos:prefLabel "File"@en, "Soubor"@cs .

#dd:zdroj a skos:Concept . 
dd:resource a skos:Concept, owl:Class  ;
    rdfs:subClassOf owl:Thing ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    skos:prefLabel "Resource"@en, "Zdroj"@cs .

#dd:je-datovým-atributem-záznamu a skos:Concept . 
dd:is-data-attribute-of-record a skos:Concept, owl:ObjectProperty ;
    rdfs:subPropertyOf dd:is-attribute-of-record  ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    rdfs:domain dd:data-attribute-of-record ;
    rdfs:range dd:record ;
    skos:prefLabel "Is data attribute of record"@en, "Je datovým atributem záznamu"@cs .

#dd:je-atributem-záznamu a skos:Concept . 
dd:is-attribute-of-record a skos:Concept, owl:ObjectProperty ;
    rdfs:subPropertyOf dd:is-attribute-of  ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    rdfs:domain dd:attribute-of-record ;
    rdfs:range dd:record ;
    skos:prefLabel "Is attribute of record"@en, "Je atributem záznamu"@cs .

#dd:má-referenční-atribut-záznamu a skos:Concept . 
dd:has-reference-attribute-of-record a skos:Concept, owl:ObjectProperty ;
    rdfs:subPropertyOf dd:has-attribute-of-record  ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    rdfs:domain dd:record ;
    rdfs:range dd:reference-attribute-of-record ;
    skos:prefLabel "Has reference attribute of record"@en, "Má referenční atribut záznamu"@cs .

#dd:má-atribut-záznamu a skos:Concept . 
dd:has-attribute-of-record a skos:Concept, owl:ObjectProperty ;
    rdfs:subPropertyOf dd:has-attribute ;
    owl:inverseOf dd:is-attribute-of-record  ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    rdfs:domain dd:record ;
    rdfs:range dd:attribute-of-record ;
    skos:prefLabel "Has attribute of record"@en, "Má atribut záznamu"@cs .

## dd:je-referenčním-atributem-záznamu a skos:Concept . 
dd:is-reference-attribute-of-record a skos:Concept, owl:ObjectProperty ;
    rdfs:subPropertyOf dd:is-attribute-of-record ;
    owl:inverseOf dd:has-reference-attribute-of-record ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    rdfs:domain dd:reference-attribute-of-record ;
    rdfs:range dd:record ;
    skos:prefLabel "Is reference attribute of record"@en, "Je referenční atribut záznamu"@cs .

## dd:má-atribut-databázové-tabulky a skos:Concept .
dd:has-attribute-of-database-table a skos:Concept, owl:ObjectProperty ;
    rdfs:subPropertyOf dd:has-attribute ;
    owl:inverseOf dd:is-attribute-of-database-table ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    rdfs:domain dd:database-table ;
    rdfs:range dd:attribute-of-database-table ;
    skos:prefLabel "Has data set attribute"@en , "Má atribut databázové tabulky"@cs .

#dd:dokument a skos:Concept . 
dd:document a skos:Concept, owl:Class ;
    rdfs:subClassOf dd:resource ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    skos:prefLabel "Document"@en, "Dokument"@cs .

#dd:má-číselníkovou-hodnotu a skos:Concept . 
dd:has-codelist-value a skos:Concept, owl:ObjectProperty ;
    rdfs:subPropertyOf dd:has-attribute-of-database-table ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    rdfs:domain dd:codelist ;
    rdfs:range dd:codelist-value ;
    skos:prefLabel "Has codelist value"@en, "Má číselníkovou hodnotu"@cs .

#dd:je-pojmem-ze-slovníku a skos:Concept . 
dd:is-term-of-vocabulary a skos:Concept, owl:ObjectProperty ;
    rdfs:subPropertyOf dd:is-term-of, skos:inScheme ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    rdfs:domain dd:term ;
    rdfs:range dd:vocabulary ;
    skos:prefLabel "Is term of vocabulary"@en, "Je pojmem ze slovníku"@cs .

#dd:slovník a skos:Concept . 
dd:vocabulary a skos:Concept, owl:Class ;
    skos:inScheme  <http://onto.fel.cvut.cz/ontologies/data-description> ;
    skos:prefLabel "Slovník"@cs, "Vocabulary"@en ;
    rdfs:subClassOf owl:Ontology , skos:ConceptScheme .

#dd:má-datum-a-čas-modifikace a skos:Concept . 
dd:has-date-and-time-of-modification a skos:Concept, owl:DatatypeProperty ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:dateTime ;
    skos:prefLabel "Has date and time of modification"@en , "Má datum a čas modifikace"@cs .

#dd:datový-atribut-záznamu a skos:Concept . 
dd:data-attribute-of-record a skos:Concept, owl:Class ;
    rdfs:subClassOf dd:attribute-of-record ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    skos:prefLabel "Data attribute of record"@en , "Datový atribut záznamu"@cs .


#dd:atribut a skos:Concept . 
dd:attribute a skos:Concept, owl:Class ;
    rdfs:subClassOf owl:Thing ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    skos:prefLabel "Attribute"@en , "Atribut"@cs .

#dd:zdroj-záznamu a skos:Concept . 
dd:source-of-record a skos:Concept, owl:Class ;
    rdfs:subClassOf dd:data-source ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    skos:prefLabel "Source of record"@en , "Zdroj záznamu"@cs .

#dd:zdroj-dat a skos:Concept . 
dd:data-source a skos:Concept, owl:Class ;
    rdfs:subClassOf owl:Thing ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    skos:prefLabel "Data source"@en , "Zdroj dat"@cs .

#dd:databázová-tabulka-jako-zdroj-dat a skos:Concept . 
dd:database-table-as-data-source a skos:Concept, owl:Class ;
    rdfs:subClassOf dd:database-table, dd:data-source ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    skos:prefLabel "Database table as the data source"@en , "Databázová tabulka jako zdroj dat"@cs .

#dd:dotaz-sql-databáze a skos:Concept . 
dd:sql-database-query a skos:Concept, owl:Class ;
    rdfs:subClassOf dd:data-source ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    skos:prefLabel "Dotaz SQL databáze"@cs , "SQL database query"@en .

#dd:má-příjmení a skos:Concept . 
dd:has-surname a skos:Concept, owl:DatatypeProperty ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    rdfs:domain dd:user ;
    rdfs:range xsd:string ;
    skos:prefLabel "Has surname"@en, "Má příjmení"@cs .

#dd:je-v-kontextu a skos:Concept . 
dd:is-in-context a skos:Concept, owl:ObjectProperty ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    rdfs:domain dd:term ;
    rdfs:range dd:resource ;
    skos:prefLabel "Is in context"@en , "Je v kontextu"@cs .

#dd:je-statistickým-atributem-záznamu a skos:Concept . 
dd:is-statistic-attribute-of-record a skos:Concept, owl:ObjectProperty ;
    rdfs:subPropertyOf dd:is-attribute-of-record  ;
    owl:inverseOf dd:has-statistic-attribute-of-record ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    rdfs:domain dd:statistic-attribute-of-record ;
    rdfs:range dd:record ;
    skos:prefLabel "Is statistic attribute of record"@en, "Je statistickým atributem záznamu"@cs .

#dd:má-statistický-atribut-záznamu a skos:Concept . 
dd:has-statistic-attribute-of-record a skos:Concept, owl:ObjectProperty ;
    rdfs:subPropertyOf dd:has-attribute-of-record ;
    owl:inverseOf dd:is-statistic-attribute-of-record ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    rdfs:domain dd:record ;
    rdfs:range dd:statistic-attribute-of-record ;
    skos:prefLabel "Has statistic attribute of record"@en, "Má statistický atribut záznamu"@cs .

#dd:má-hodnotu-z-číselníku a skos:Concept . 
dd:has-value-from-codelist a skos:Concept, owl:ObjectProperty ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    rdfs:domain dd:attribute-of-database-table ;
    rdfs:range dd:codelist ;
    skos:prefLabel "Has value from codelist"@en, "Má hodnotu z číselníku"@cs .

#dd:referenční-atribut-záznamu a skos:Concept . 
dd:reference-attribute-of-record a skos:Concept, owl:Class ;
    rdfs:subClassOf dd:attribute-of-record ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    skos:prefLabel "Reference attribute of record"@en,  "referenční atribut záznamu"@cs .

#dd:je-v-kontextu-datové-sady a skos:Concept . 
dd:is-in-context-of-dataset a skos:Concept, owl:ObjectProperty ;
    rdfs:subPropertyOf dd:is-in-context ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    rdfs:range dd:dataset ;
    skos:prefLabel "Is in context of dataset"@en, "Je v kontextu datové sady"@cs .

#dd:dokument-legislativní-povahy  a skos:Concept . 
dd:document-of-legislative-nature a skos:Concept, owl:Class ;
    rdfs:subClassOf dd:document ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    skos:prefLabel "Document of legislative nature"@en, "Dokument legislativní povahy"@cs .

#dd:číselníková-hodnota a skos:Concept . 
dd:codelist-value a skos:Concept, owl:Class ;
    rdfs:subClassOf dd:attribute-of-database-table ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    skos:prefLabel "Codelist value"@en , "Číselníková hodnota"@cs .

#dd:atribut-databázové-tabulky a skos:Concept . 
dd:attribute-of-database-table a skos:Concept, owl:Class ;
    rdfs:subClassOf dd:attribute ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    skos:prefLabel "Atribut databázové tabulky"@cs, "Attribute of databse table"@en .

#dd:je-atributem a skos:Concept . 
dd:is-attribute-of a skos:Concept, owl:ObjectProperty ;
    owl:inverseOf dd:has-attribute ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    rdfs:domain dd:attribute ;
    rdfs:range owl:Thing ;
    skos:prefLabel "Is attribute of"@en, "Je atributem"@cs .

#dd:je-atributem-databázové-tabulky a skos:Concept . 
dd:is-attribute-of-database-table a skos:Concept, owl:ObjectProperty ;
    rdfs:subPropertyOf dd:is-attribute-of ;
    skos:inScheme <http://onto.fel.cvut.cz/ontologies/data-description> ;
    rdfs:domain dd:attribute-of-database-table ;
    rdfs:range dd:database-table ;
    skos:prefLabel "Is attribute of database table"@en, "Je atributem databázové tabulky"@cs .

#dd:má-autora a skos:Concept . 
dd:has-author a skos:Concept, owl:ObjectProperty ;
